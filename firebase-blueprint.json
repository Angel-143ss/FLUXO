{
  "entities": {
    "Perfil": {
      "title": "Perfil de Usuario",
      "description": "Información de perfil del usuario y sus respuestas de onboarding.",
      "type": "object",
      "properties": {
        "nombre": { "type": "string" },
        "disciplina": { "type": "string" },
        "catalizador": { "type": "string" },
        "saboteador": { "type": "string" },
        "onboardingCompleto": { "type": "boolean" }
      },
      "required": ["nombre", "onboardingCompleto"]
    },
    "Progreso": {
      "title": "Progreso del Usuario",
      "description": "Estadísticas y progreso acumulado del usuario.",
      "type": "object",
      "properties": {
        "ejerciciosCompletados": { "type": "number" },
        "rachaActual": { "type": "number" },
        "ultimoEjercicio": { "type": "string" },
        "totalSesiones": { "type": "number" }
      },
      "required": ["ejerciciosCompletados", "rachaActual", "totalSesiones"]
    },
    "HistorialEntry": {
      "title": "Entrada de Historial",
      "description": "Detalles de un ejercicio creativo completado.",
      "type": "object",
      "properties": {
        "fecha": { "type": "string" },
        "tipo": { "type": "string" },
        "duracion": { "type": "number" },
        "estado": { "type": "string" }
      },
      "required": ["fecha", "tipo", "duracion", "estado"]
    }
  },
  "firestore": {
    "/usuarios/{userId}/perfil/perfil": {
      "schema": "Perfil",
      "description": "Documento de perfil del usuario."
    },
    "/usuarios/{userId}/progreso/progreso": {
      "schema": "Progreso",
      "description": "Documento de estadísticas de progreso del usuario."
    },
    "/usuarios/{userId}/historial/{ejercicioId}": {
      "schema": "HistorialEntry",
      "description": "Ejercicios individuales completados."
    }
  }
}
